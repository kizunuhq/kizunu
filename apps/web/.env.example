VITE_API_URL=http://localhost:3001
# Meta App + Configuration IDs for WhatsApp Coex Embedded Signup (feature 031).
# Required only when the Connect WhatsApp via Embedded Signup flow is used. The
# app secret stays server-side (apps/api). Vite inlines these at dev-server
# startup, so the dev server must be restarted after changing them.
VITE_META_APP_ID=
VITE_META_COEX_CONFIG_ID=
