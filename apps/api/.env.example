NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
# Web app origin the browser lands on after an OAuth redirect.
APP_WEB_URL=http://localhost:3000
APP_CORS_ORIGINS=http://localhost:3000
APP_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kizunu_dev
APP_SESSION_COOKIE_NAME=kizunu_session
APP_SESSION_TTL_DAYS=30
APP_SESSION_COOKIE_SECURE=false
# Self-host registration gate. Leave false to allow public signup; set true to
# block POST /auth/register (invite/accept-invite stays open) after registering
# the first user.
DISABLE_USER_REGISTRATION=false
# OAuth/SSO login. A provider is enabled only when both id and secret are set.
# GitHub callback URL to register: ${APP_URL}/auth/oauth/github/callback
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
# AES-256 key for at-rest encryption of provider credentials (channel_accounts
# and connector_accounts credentials JSONB columns). Required; generate with:
#   openssl rand -base64 32
APP_CREDENTIALS_ENCRYPTION_KEY=
