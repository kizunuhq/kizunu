{
  "name": "@kizunu/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/main.ts",
    "start": "bun run src/main.ts",
    "build": "nest build --builder swc",
    "check-types": "tsc --noEmit",
    "test": "bun test --pass-with-no-tests",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun run seed.ts"
  },
  "dependencies": {
    "@kizunu/api-contracts": "workspace:*",
    "@kizunu/config-module": "workspace:*",
    "@kizunu/nestjs-shared": "workspace:*",
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.4.0",
    "cookie-parser": "^1.4.7",
    "drizzle-orm": "catalog:",
    "nestjs-zod": "^5.2.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/testing": "^11.1.17",
    "@swc/cli": "^0.7.8",
    "@swc/core": "^1.13.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "catalog:",
    "supertest": "^7.1.1",
    "typescript": "catalog:"
  }
}
