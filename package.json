{
  "name": "kizunu",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "typescript": "^5.9.3",
      "drizzle-orm": "^0.45.1",
      "drizzle-kit": "^0.31.10",
      "zod": "^4.3.6"
    }
  },
  "type": "module",
  "scripts": {
    "prepare": "simple-git-hooks",
    "dev": "bunx vp run --parallel dev",
    "build": "bunx vp run -r build",
    "test": "bunx vp test",
    "typecheck": "bunx vp run -r check-types",
    "lint": "bunx vp lint apps packages scripts",
    "format": "bunx vp fmt --write .",
    "fix": "bunx vp check --fix",
    "check": "bash scripts/check.sh",
    "pre-commit": "bun scripts/hooks/pre-commit.ts",
    "commitlint": "commitlint",
    "db:up": "bun scripts/db.ts up",
    "db:down": "bun scripts/db.ts down",
    "db:migrate": "bun scripts/db.ts migrate",
    "db:setup": "bun scripts/db.ts setup",
    "db:reset": "bun scripts/db.ts reset",
    "db:generate": "bun --filter @kizunu/api db:generate"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@types/bun": "latest",
    "simple-git-hooks": "^2.13.1",
    "vite-plus": "^0.1.20"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.20"
  },
  "simple-git-hooks": {
    "pre-commit": "bun pre-commit",
    "commit-msg": "bun commitlint --edit $1"
  },
  "packageManager": "bun@1.3.13"
}
