{
  "name": "kizunu",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "typescript": "^5.9.3"
    }
  },
  "type": "module",
  "scripts": {
    "prepare": "simple-git-hooks",
    "dev": "bunx vp run --parallel dev",
    "build": "bunx vp run -r build",
    "test": "bunx vp test",
    "typecheck": "bunx vp run -r check-types",
    "lint": "bunx vp lint .",
    "format": "bunx vp fmt --write .",
    "fix": "bunx vp check --fix",
    "check": "bash scripts/check.sh",
    "pre-commit": "bun scripts/hooks/pre-commit.ts",
    "commitlint": "commitlint"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@types/bun": "latest",
    "simple-git-hooks": "^2.13.1",
    "vite-plus": "^0.1.20"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.20"
  },
  "simple-git-hooks": {
    "pre-commit": "bun pre-commit",
    "commit-msg": "bun commitlint --edit $1"
  },
  "packageManager": "bun@1.3.13"
}
