# Operator overrides for `docker compose -f deploy/docker-compose.yml ...`.
# Copy this file to `deploy/.env` and fill in the values you need. The compose
# file reads from here via ${VAR:-} interpolation; anything left empty falls
# back to the in-file default.
#
# Names here are intentionally *unprefixed*. The compose file forwards them
# into the api container as-is, and into the web container with the `VITE_`
# prefix Vite expects — so a single value here covers both services.
#
# This file is only consumed by docker compose. When running the apps
# natively (`bun dev` outside Docker), each app reads its own env:
#   - apps/api/.env  (plain names: META_APP_ID, ...)
#   - apps/web/.env  (Vite names:  VITE_META_APP_ID, ...)

# Meta App credentials for WhatsApp Coex Embedded Signup (feature 031).
# Required only when the Connect WhatsApp via Embedded Signup flow is used.
# Find them at developers.facebook.com -> your app:
#   META_APP_ID         -> dashboard top bar, "App ID"
#   META_APP_SECRET     -> App settings -> Basic -> App Secret
#   META_COEX_CONFIG_ID -> App settings -> Facebook Login for Business
#                          -> Configurations -> your Coex config (numeric ID)
META_APP_ID=
META_APP_SECRET=
META_COEX_CONFIG_ID=
